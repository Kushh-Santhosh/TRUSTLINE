# ─────────────────────────────────────────────────────────────────────────────
# TrustLine Frontend — Environment Variables
# Copy this file to .env.local for local development overrides.
#   cp .env.example .env.local
#
# DO NOT commit .env.local or .env — both are listed in .gitignore.
# Vite only exposes variables prefixed with VITE_ to the browser bundle.
# ─────────────────────────────────────────────────────────────────────────────

# ── API base URL (optional — defaults to http://localhost:4000) ───────────
# In Docker Compose this is baked into the build via ARG VITE_API_URL.
# For local dev with `npm run dev`, set it here if the backend runs elsewhere.
VITE_API_URL=http://localhost:4000
