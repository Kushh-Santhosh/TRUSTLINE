{
  "name": "trustline-backend",
  "version": "0.1.0",
  "private": true,
  "description": "TrustLine backend API",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "migrate:up": "node -r dotenv/config ./node_modules/.bin/node-pg-migrate -m migrations up",
    "migrate:down": "node -r dotenv/config ./node_modules/.bin/node-pg-migrate -m migrations down",
    "migrate:create": "node -r dotenv/config ./node_modules/.bin/node-pg-migrate -m migrations create",
    "seed": "ts-node -r dotenv/config src/scripts/seed.ts",
    "verify-chain": "ts-node -r dotenv/config src/scripts/verifyChain.ts"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.14.10",
    "@types/pg": "^8.20.0",
    "@types/pino-http": "^5.8.4",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "prettier": "^3.9.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.4"
  },
  "dependencies": {
    "@simplewebauthn/server": "^13.3.2",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "node-pg-migrate": "^9.0.0",
    "otplib": "^13.4.1",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0"
  }
}
