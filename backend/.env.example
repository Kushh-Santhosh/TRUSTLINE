# ─────────────────────────────────────────────────────────────────────────────
# TrustLine Backend — Environment Variables
# Copy this file to .env and fill in real values before running locally.
#   cp .env.example .env
#
# DO NOT commit .env — it is listed in .gitignore.
# For Docker Compose, set these via environment: in docker-compose.yml or
# by creating a .env file at the repo root (Docker Compose auto-loads it).
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (required) ───────────────────────────────────────────────────
# Local dev: postgres is started by docker-compose or a local Postgres install.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/trustline

# ── Redis (required) ──────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT Secrets (required) ────────────────────────────────────────────────
# Generate fresh values for every environment:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-secret
JWT_REFRESH_SECRET=change-me-to-a-different-long-random-secret

# ── Server (optional) ─────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
LOG_LEVEL=info

# ── CORS (optional) ────────────────────────────────────────────────────────
# Comma-separated origins are supported. Both common Vite development ports
# are accepted by default so local development still works when 5173 is busy.
# Override in production with the real frontend URL only.
FRONTEND_ORIGIN=http://localhost:5173,http://localhost:5174

# ── WebAuthn (optional — defaults to 'localhost') ─────────────────────────
# Must match the domain where the frontend is served.
# For local dev, 'localhost' is correct.
# In production, set to your actual domain (e.g. trustline.example.com).
WEBAUTHN_RP_ID=localhost

# ── Load-test script (optional) ───────────────────────────────────────────
# Used only by src/scripts/loadTest.ts — not read by the server.
# BACKEND_URL=http://localhost:4000
